generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model app_ping {
  id         BigInt   @id @default(autoincrement())
  message    String
  created_at DateTime @default(now()) @db.Timestamptz(6)
}

model match_history {
  id               String       @id
  user_id          String
  result           match_result
  score_delta      Int          @default(0)
  win_streak_after Int          @default(0)
  created_at       DateTime     @default(now()) @db.Timestamptz(6)
  users            users        @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id, created_at], map: "idx_match_history_user_created_at")
}

model users {
  id            String          @id
  email         String          @unique
  score         Int             @default(0)
  win_streak    Int             @default(0)
  created_at    DateTime        @default(now()) @db.Timestamptz(6)
  match_history match_history[]
}

enum match_result {
  WIN
  LOSE
  DRAW
}
